<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="SalaryDetailItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">6dp</item>
    </style>

    <style name="SalaryLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/role_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SalaryValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginStart">8dp</item>
    </style>

    <style name="Theme.MySplash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_splash</item>
        <item name="android:statusBarColor">@color/bg_splash</item>
    </style>
    <!-- Paste kode ini di dalam file themes.xml atau styles.xml -->

    <!-- Style untuk baris item gaji (pembungkus) -->
    <style name="SalaryRowStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical" tools:targetApi="26">8dp</item>
    </style>

    <!-- Style untuk label teks di sebelah kiri -->
    <style name="SalaryLabelStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#616161</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Style untuk nilai/nominal di sebelah kanan -->
    <style name="SalaryValueStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#212121</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>

